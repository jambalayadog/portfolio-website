---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';

const home = await getEntry('pages', 'home');
if (!home) throw new Error('Missing pages/home.md');
const { Content } = await render(home);
const { title, eyebrow, tagline, workHeading } = home.data;

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Jordan Watt · Game Designer">
  <section class="hero container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {tagline && <p class="tagline">{tagline}</p>}
    <div class="intro"><Content /></div>
  </section>

  <section class="section container">
    <div class="section-head">
      <h2>{workHeading ?? 'Selected Work'}</h2>
      <a href="/about">About me →</a>
    </div>
    <div class="grid">
      {work.map((entry) => (
        <WorkCard
          slug={entry.id}
          title={entry.data.title}
          cardTitle={entry.data.cardTitle}
          studio={entry.data.studio}
          boxart={entry.data.boxart}
          role={entry.data.role}
          focus={entry.data.focus}
          year={entry.data.year}
          status={entry.data.status}
        />
      ))}
    </div>
  </section>
</BaseLayout>
