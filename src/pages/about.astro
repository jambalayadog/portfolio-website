---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveImage } from '../lib/images';
import breadth from '../data/breadth.json';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing pages/about.md');
const { Content } = await render(entry);

// Map a box-art filename → the game's display name (for thumbnail tooltips),
// derived from the work entries, with overrides where the art ≠ its entry title.
const work = await getCollection('work');
const nameByFile = new Map<string, string>();
for (const w of work) {
  const f = w.data.boxart.split('/').pop();
  if (f) nameByFile.set(f, w.data.title);
}
nameByFile.set('Madden06.jpg', 'Madden NFL 06');
const gameName = (file: string) => nameByFile.get(file.split('/').pop() ?? '') ?? '';

type Game = string | { img: string; note?: string };
const groups = Object.entries(breadth) as [string, { label: string; games: Game[] }[]][];
---

<BaseLayout title="About — Jordan Watt">
  <article class="article container">
    <header class="article__head">
      <p class="eyebrow">{entry.data.subtitle}</p>
      <h1>{entry.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>

    {groups.map(([title, items]) => (
      <section class="section">
        <div class="section-head"><h2>{title}</h2></div>
        <div class="matrix">
          {items.map((it) => (
            <div class="matrix__item">
              <span class="matrix__label">{it.label}</span>
              <span class="matrix__thumbs">
                {it.games.map((g) => {
                  const file = typeof g === 'string' ? g : g.img;
                  const note = typeof g === 'string' ? null : g.note;
                  const img = resolveImage(file);
                  if (!img) return null;
                  const name = gameName(file);
                  return (
                    <button class="matrix__thumb" type="button" aria-label={name}>
                      <Image src={img} alt="" width={96} loading="lazy" />
                      {note && <sup class="matrix__note">{note}</sup>}
                      <span class="matrix__tip" aria-hidden="true">{name}</span>
                    </button>
                  );
                })}
              </span>
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="matrix-footnote">* Open-world design within specific levels (e.g. Hardline's "Legacy").</p>

  </article>
</BaseLayout>
