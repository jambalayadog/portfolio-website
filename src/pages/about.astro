---
import { Image } from 'astro:assets';
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveImage } from '../lib/images';
import breadth from '../data/breadth.json';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing pages/about.md');
const { Content } = await render(entry);

const groups = Object.entries(breadth) as [string, { label: string; games: string[] }[]][];
---

<BaseLayout title="About — Jordan Watt">
  <article class="article container">
    <header class="article__head">
      <p class="eyebrow">{entry.data.subtitle}</p>
      <h1>{entry.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>

    {groups.map(([title, items]) => (
      <section class="section">
        <div class="section-head"><h2>{title}</h2></div>
        <div class="matrix">
          {items.map((it) => (
            <div class="matrix__item">
              <span class="matrix__thumbs">
                {it.games.map((g) => {
                  const img = resolveImage(g);
                  return img ? <Image src={img} alt="" width={96} loading="lazy" /> : null;
                })}
              </span>
              <span class="matrix__label">{it.label}</span>
            </div>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>
