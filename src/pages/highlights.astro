---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveImage } from '../lib/images';

const items = (await getCollection('highlights')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  items.map(async (item) => ({
    item,
    Content: (await render(item)).Content,
    img: resolveImage(item.data.image),
  })),
);
---

<BaseLayout title="Highlights — Jordan Watt" description="Side projects, hobby builds, and career highlights.">
  <article class="article container">
    <header class="article__head">
      <p class="eyebrow">Extras</p>
      <h1>Highlights</h1>
      <p class="article__meta">Side projects, hobby builds, and a few career moments.</p>
    </header>

    <div class="highlight-list">
      {rendered.map(({ item, Content, img }) => (
        <div class="highlight">
          {img && (
            <div class="highlight__img">
              <Image src={img} alt={item.data.title} width={480} loading="lazy" />
            </div>
          )}
          <div class="highlight__body">
            <h3>{item.data.title}</h3>
            <div class="prose"><Content /></div>
          </div>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
