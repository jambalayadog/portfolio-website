---
import { Image } from 'astro:assets';
import { resolveImage } from '../lib/images';

interface Props {
  slug: string;
  title: string;
  studio: string;
  boxart: string;
  year?: number;
  status?: string;
}
const { slug, title, studio, boxart, year, status } = Astro.props;
const art = resolveImage(boxart);
---

<a class="card" href={`/work/${slug}`}>
  <div class="card__art">
    {art && <Image src={art} alt={`${title} box art`} width={400} loading="lazy" />}
  </div>
  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__meta">
      <span>{studio}</span>
      {year ? <span>· {year}</span> : status ? <span class="badge">{status}</span> : null}
    </p>
  </div>
</a>
